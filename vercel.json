{
  "framework": "nextjs",
  "regions": ["sin1"],
  "crons": [
    {
      "path": "/api/dmama/sync",
      "schedule": "0 2 2 * *"
    },
    {
      "path": "/api/dmama/flow-sync",
      "schedule": "0 4 2 * *"
    },
    {
      "path": "/api/dmama/sync",
      "schedule": "0 2 16 * *"
    },
    {
      "path": "/api/dmama/flow-sync",
      "schedule": "0 4 16 * *"
    },
    {
      "path": "/api/dmama/mnf-sync?mode=daily",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/dmama/mnf-sync?mode=daily",
      "schedule": "0 7 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
